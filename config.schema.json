{
  "pluginAlias": "TasmotaHttp",
  "pluginType": "platform",
  "singular": true,

  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",

  "schema": {
    "type": "object",
    "properties": {
      "scanSubnet": {
        "title": "Scan Subnet",
        "type": "string",
        "placeholder": "10.0.1.0/24",
        "description": "The /24 network to scan for Tasmota devices, e.g. 10.0.1.0/24."
      },
      "devices": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true
            },
            "host": {
              "type": "string",
              "required": true
            },
            "port": {
              "type": "integer",
              "default": 80
            },
            "pollInterval": {
              "type": "integer",
              "default": 2
            },
            "type": {
              "title": "Device Type",
              "type": "string",
              "enum": ["light", "switch"],
              "default": "light"
            }
          },
          "required": [
            "name",
            "host"
          ]
        }
      }
    }
  }
}