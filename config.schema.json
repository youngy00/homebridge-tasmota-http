{
  "pluginAlias": "TasmotaHttp",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "devices": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "required": true
            },
            "host": {
              "type": "string",
              "required": true
            },
            "port": {
              "type": "integer",
              "default": 80
            },
            "pollInterval": {
              "type": "integer",
              "default": 15
            }
          },
          "required": ["name", "host"]
        }
      }
    }
  }
}
