{
  "name": "homebridge-tasmota-local",
  "displayName": "Homebridge Tasmota Local",
  "version": "0.3.0",
  "description": "Native HTTP Homebridge platform for Tasmota devices",
  "author": {
    "name": "youngy00",
    "url": "https://github.com/youngy00"
  },
  "homepage": "https://github.com/youngy00/homebridge-tasmota-http",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youngy00/homebridge-tasmota-http.git"
  },
  "bugs": {
    "url": "https://github.com/youngy00/homebridge-tasmota-http/issues"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "tasmota",
    "http",
    "local",
    "iot",
    "apple-home"
  ],
"scripts": {
  "build": "npm run build:ui && npm run build:server",
  "build:ui": "npm --prefix ui install && npm --prefix ui run build",
  "build:server": "tsc -p tsconfig.json && tsc -p homebridge-ui/tsconfig.json",
  "watch": "tsc -w -p tsconfig.json",
  "prepublishOnly": "npm run build"
},
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=2.1.1"
  },
  "peerDependencies": {
    "homebridge": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.5"
  }
}
